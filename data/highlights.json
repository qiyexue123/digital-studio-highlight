            "items": [
              {
                "label": "⚡ AI 自动决策边界",
                "title": "任务编排层",
                "desc": "系统自动拆解用户意图为子任务序列，无需用户逐步确认。适用于文件处理、信息聚合、格式转换等标准化流程。",
                "boundary": "auto",
                "boundaryText": "自动执行·无需人工干预"
